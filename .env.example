# ===========================================
# Cloud Agent Platform - Environment Variables
# ===========================================

# EasyStack ECF 6.2.1 Configuration
EASYSTACK_AUTH_URL=https://your-easystack-keystone-url:5000
EASYSTACK_USERNAME=admin
EASYSTACK_PASSWORD=your-password
EASYSTACK_DOMAIN=default
EASYSTACK_PROJECT=admin
EASYSTACK_PROJECT_ID=your-project-id

# AI Provider Configuration
# Supported: openai, azure
AI_PROVIDER=openai
AI_API_KEY=sk-your-api-key
AI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4

# Alternative: Use DeepSeek or other OpenAI-compatible APIs
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_MODEL=deepseek-chat
# AI_API_KEY=sk-your-deepseek-key

# Alternative: Use Qwen (Tongyi Qianwen)
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_MODEL=qwen-plus
# AI_API_KEY=sk-your-qwen-key
